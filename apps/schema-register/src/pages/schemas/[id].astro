---
export const prerender = false; // Not needed in 'server' mode

import {
  API_ENDPOINT,
  API_URL,
  API_VERSION,
  API_X_API_KEY,
  PIWIK_PRO_ACCOUNT_ADDRESS,
  PIWIK_PRO_SITE_ID,
} from "astro:env/server";
import {
  Alert,
  Block,
  DataSummary,
  DataSummaryItem,
  Heading,
  HeadingGroup,
  Link,
  Markdown,
  Paragraph,
  PillBadge,
} from "@developer-overheid-nl/don-register-components";
import { PiwikPro } from "@developer-overheid-nl/don-register-components/analytics";
import i18n from "@developer-overheid-nl/don-register-components/i18n";
import {
  DonBasic,
  DonDetail,
} from "@developer-overheid-nl/don-register-layouts";
import { t } from "i18next";
import createClient from "openapi-fetch";
import appConfig from "../../../app.config";
import { ApiPaths, type paths } from "../../types/api-schema";

const { id = "" } = Astro.params;
const API_RESOURCE = ApiPaths.getSchemaById;

const client = createClient<paths>({
  baseUrl: `${API_URL}/${API_ENDPOINT}/${API_VERSION}`,
});
const {
  data,
  error,
  response: { status, statusText, headers },
} = await client.GET(API_RESOURCE, {
  params: {
    path: { id },
  },
  headers: {
    "x-api-key": API_X_API_KEY,
  },
});

// Localization
const { i18n: i18nApp } = appConfig;
const i18nPage = {
  "pages.aside-landmark": "Contactinformatie",
};
i18n.addResourceBundle(
  i18n.language,
  "translation",
  i18nApp ? i18nApp[i18n.language] : {},
  true,
  true,
);
i18n.addResources(i18n.language, "translation", i18nPage);

const details = error ? null : data;

const rawSchemaUrl = `${API_URL}/${API_ENDPOINT}/${API_VERSION}/schemas/${id}/schema.json`;
const prettySchema = details?.content
  ? JSON.stringify(details.content, null, 2)
  : null;
---

{ error && (
  <DonBasic appConfig={appConfig} titlePage="Schema niet gevonden">
    <Alert type="error">{(error as unknown as any).message || (error as unknown as any).detail || `${status}: ${statusText}` || t('components.fuzz-error')}</Alert>
    <Paragraph>{t('components.item-not-found-error')}</Paragraph>
  </DonBasic>
)}

{details && (
  <DonDetail appConfig={appConfig} titlePage={details?.title}>
    <PiwikPro slot="head" client:only="react"
      accountAddress={PIWIK_PRO_ACCOUNT_ADDRESS}
      siteId={PIWIK_PRO_SITE_ID}
    />
    <HeadingGroup
      slot="header"
      title={`${t(`pages.details-of-item`)}: ${details?.title}`}
      level={2}
      data-track-content
      data-content-name="Detail Page Header"
    >
      <div class="subtitle" slot="subTitle">
        <Paragraph data-content-piece="Organisation Name" itemScope={true} itemType="https://schema.org/Organization" itemID={details?.organisation?.uri} className={`styles.aboveLink styles.publisher`}>
          <span itemprop="name"><Link data-content-target="Organisation Link" className={`styles.orgLink`} href={new URL(`./?organisation=${details?.organisation?.uri}`, Astro.url).toString()}>
              {details?.organisation?.label}
          </Link></span>
        </Paragraph>
      </div>
    </HeadingGroup>
    <Fragment slot="description">
      <Heading level={3} className="sr-only">{t(`pages.description`)}</Heading>
      <div class="utrecht-html"><Markdown text={details.description} minHeadingDepth={4} /></div>
    </Fragment>
    <Fragment slot="aside">
      <DataSummary appearance="row">
        <DataSummaryItem itemKey="Organisatie" itemValue={details?.organisation?.label || '-'} />
        <DataSummaryItem itemKey="Contactpersoon" itemValue={details?.contact?.name || '-'} />
        <DataSummaryItem itemKey="Email" itemValue={details?.contact?.email || '-'} />
      </DataSummary>
    </Fragment>
    <Fragment slot="meta">
      <Block layout="flex-row">
        <PillBadge startValue={`dialect`} endValue={details.dialect || 'unknown'} type="color" color={details.dialect && details.dialect !== 'unknown' ? "mintgroen" : "grijs"} />
        <PillBadge startValue={`type`} endValue={details.rootType || 'unknown'} type="color" color={details.rootType && details.rootType !== 'unknown' ? "lichtblauw" : "grijs"} />
        { details.collection && (
          <PillBadge startValue={`collectie`} endValue={details.collection} type="color" color="coolgrey" />
        )}
      </Block>
      <Heading level={4}>{t(`pages.details`)}</Heading>
      <Block appearance="outlined">
        <Heading level={5}>{t(`pages.links`)}</Heading>
        <DataSummary appearance="column" contained>
          { details.schemaUrl && (
            <DataSummaryItem itemKey="Schema URL" itemValue="" href={details.schemaUrl}>{details.schemaUrl}</DataSummaryItem>
          )}
          <DataSummaryItem itemKey="Download" itemValue="" href={rawSchemaUrl}>schema.json</DataSummaryItem>
        </DataSummary>
      </Block>
      { prettySchema && (
        <Fragment>
          <Heading level={4}>JSON Schema</Heading>
          <Block appearance="outlined" className="schema-content">
            <pre class="schema-pre"><code>{prettySchema}</code></pre>
          </Block>
        </Fragment>
      )}
      <Heading level={4}>{t(`pages.tbd-metadata`)}</Heading>
      <Block appearance="outlined">
        <DataSummary appearance="column" contained>
          <DataSummaryItem itemKey={t(`components.created-at`)} itemValue={new Date(details.createdAt as string | number).toLocaleDateString('nl-NL')} />
          <DataSummaryItem itemKey={t(`components.last-crawled-at`)} itemValue={new Date(details.lastCrawledAt as string | number).toLocaleDateString('nl-NL')} />
        </DataSummary>
      </Block>
    </Fragment>
  </DonDetail>
  )
}

<style>
  .subtitle {
    display: flex;
    justify-content: space-between;
  }

  .schema-content {
    overflow-x: auto;
  }

  .schema-pre {
    margin: 0;
    padding: 0.5rem;
    font-size: 0.875rem;
    line-height: 1.5;
    background-color: rgb(from var(--rhc-color-cool-grey-50) r g b / 0.5);
    overflow-x: auto;
  }
</style>
