---
export const prerender = false; // Not needed in 'server' mode

import {
  API_ENDPOINT,
  API_URL,
  API_VERSION,
  API_X_API_KEY,
  PIWIK_PRO_ACCOUNT_ADDRESS,
  PIWIK_PRO_SITE_ID,
} from "astro:env/server";
import {
  Alert,
  AlignBox,
  Block,
  CopyButton,
  DataBadgeLink,
  DataSummary,
  DataSummaryItem,
  Heading,
  HeadingGroup,
  Icon,
  Link,
  Markdown,
  Paragraph,
  PillBadge,
  ReadOnlyTextInput,
} from "@developer-overheid-nl/don-register-components";
import { PiwikPro } from "@developer-overheid-nl/don-register-components/analytics";
import i18n from "@developer-overheid-nl/don-register-components/i18n";
import {
  DonBasic,
  DonDetail,
} from "@developer-overheid-nl/don-register-layouts";
import { t } from "i18next";
import createClient from "openapi-fetch";
import appConfig from "../../../app.config";
import {
  getFromDate,
  getStatus,
  getStatusColor,
} from "../../components/lifecycleHelpers";
import { ApiPaths, type paths } from "../../types/api-schema";

type ProcessingEventStatus = "failed" | "fallback_succeeded" | string;

type ProcessingEvent = {
  tool: string;
  status: ProcessingEventStatus;
  message: string;
  detail?: string;
  createdAt: string;
};

type ApiDetailWithProcessingEvents = NonNullable<typeof data> & {
  processingEvents?: ProcessingEvent[];
};

Astro.response.headers.set("Cache-Control", "public, max-age=7200");
const { id = "" } = Astro.params;
const API_RESOURCE = ApiPaths.retreiveApi;

const client = createClient<paths>({
  baseUrl: `${API_URL}/${API_ENDPOINT}/${API_VERSION}`,
});
const {
  data,
  error,
  response: { headers },
} = await client.GET(API_RESOURCE, {
  params: {
    path: { id },
  },
  headers: {
    "x-api-key": API_X_API_KEY,
  },
});

// Localization
const { i18n: i18nApp } = appConfig;
const i18nPage = {
  "pages.aside-landmark": "Contactinformatie",
};
i18n.addResourceBundle(
  i18n.language,
  "translation",
  i18nApp ? i18nApp[i18n.language] : {},
  true,
  true,
);
i18n.addResources(i18n.language, "translation", i18nPage);

const details = error ? null : data;
const processingEvents = (
  (details as ApiDetailWithProcessingEvents | null)?.processingEvents ?? []
).filter((event) => event.status === "failed");
const latestProcessingError = processingEvents.sort((a, b) => {
  const aTime = new Date(a.createdAt).getTime();
  const bTime = new Date(b.createdAt).getTime();
  return (Number.isNaN(bTime) ? 0 : bTime) - (Number.isNaN(aTime) ? 0 : aTime);
})[0];
const rssFeedUrl = `https://api.developer.overheid.nl/api-register/v1/apis/${encodeURIComponent(id)}/feed.rss`;
const slackFeedSubscribeCommand = `/feed subscribe ${rssFeedUrl}`;

const processingToolLabels: Record<string, string> = {
  oas_bundle: "OAS bundelen",
  oas_fetch: "OAS ophalen",
  oas_artifacts: "OAS-bestanden opslaan",
  lint: "Linten",
  postman: "Postman collectie",
  arazzo_markdown: "Arazzo markdown",
  arazzo_mermaid: "Arazzo Mermaid",
  typesense: "Zoekindex",
};

const processingStatusLabels: Record<string, string> = {
  failed: "Mislukt",
  fallback_succeeded: "Fallback gebruikt",
};

const formatProcessingEventDate = (value: string) => {
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) {
    return "";
  }
  return new Intl.DateTimeFormat("nl-NL", {
    dateStyle: "medium",
    timeStyle: "short",
  }).format(date);
};
---

{ error && (
  <DonBasic appConfig={appConfig} titlePage="API niet gevonden">
    {/* biome-ignore lint/suspicious/noExplicitAny: error handling needs any at this moment */}
    <Alert type="error">{(error as unknown as any).message || (error as unknown as any).detail || t('components.fuzz-error')}</Alert>
    <Paragraph>{t('components.item-not-found-error')}</Paragraph>
  </DonBasic>
)}

{details && (
  <DonDetail appConfig={appConfig} titlePage={details.title}>
    <PiwikPro slot="head" client:only="react" 
      accountAddress={PIWIK_PRO_ACCOUNT_ADDRESS} 
      siteId={PIWIK_PRO_SITE_ID} 
    />
    <HeadingGroup
      slot="header"
      title={`${t(`pages.details-of-item`)}: ${details.title}`}
      level={2} 
      data-track-content
      data-content-name="Detail Page Header"
    >
      <Paragraph data-content-piece="Organisation Name" itemScope={true} itemType="https://schema.org/Organization" itemID={details?.organisation?.uri} className={`styles.aboveLink styles.publisher`}>
          <span itemprop="name"><Link data-content-target="Organisation Link" className={`styles.orgLink`} href={new URL(`./?organisation=${details?.organisation?.uri}`, Astro.url).toString()}>
              {details.organisation?.label}
          </Link></span>
      </Paragraph>
    </HeadingGroup>
    { /* biome-ignore lint/complexity/noUselessFragments: needed for slot */ }
    <Fragment slot="description">
      <Heading level={3} className="sr-only">{t(`pages.description`)}</Heading>
      <div class="utrecht-html"><Markdown text={details.description} minHeadingDepth={4} /></div>
    </Fragment>
    { /* biome-ignore lint/complexity/noUselessFragments: needed for slot */ }
    <Fragment slot="aside">
      <DataSummary appearance="row">
        <DataSummaryItem itemKey="Organisatie" itemValue={details.organisation?.label || '-'} />
        <DataSummaryItem itemKey="Contactpersoon" itemValue={details.contact?.name || '-'} />
        <DataSummaryItem itemKey="Email" itemValue={details.contact?.email || '-'} />
        <DataSummaryItem itemKey="URL" href={details.contact?.url} itemValue="">{details.contact?.url || '-'}</DataSummaryItem>
      </DataSummary>
    </Fragment>
    { /* biome-ignore lint/complexity/noUselessFragments: needed for slot */ }
    <Fragment slot="meta">
      <Block layout="flex-row" data-track-content data-content-name="Detail Page Meta">
        <PillBadge 
          startValue={t('components.version', {version: details.lifecycle.version})} 
          endValue={t(`components.lifecycle-status-${getStatus(details.lifecycle)?.current || 'active'}`, {...getFromDate(details.lifecycle)})} 
          type="color"
          color={getStatusColor(details.lifecycle)}
          data-status={JSON.stringify(getStatus(details.lifecycle))}
        />
        <AlignBox gap="small" display="inline">
          <PillBadge data-content-piece="ADR Score" className="adr-score-figure" startValue={`ADR Score`} endValue={details.adrScore} type="percentage">
            <span class="adr-score-info"><Link data-content-target="DON Checker Link" href={`https://developer-overheid-nl.github.io/don-checker/#/adr-21?url=${encodeURIComponent(`https://apis.developer.overheid.nl/apis/download/${id}/oas3.0.json`)}`} target="_blank" rel="noopener noreferrer">Uitleg <Icon name="externe-link-inline" /></Link></span>
          </PillBadge>
        </AlignBox>
      </Block>
      { latestProcessingError ? (
        <Alert type="error" className="processing-events-alert">
          <strong>Verwerking van deze API is niet volledig gelukt</strong>
          <Paragraph>
            Een verwerkingsstap is mislukt. Sommige afgeleide bestanden, scores of zoekresultaten kunnen ontbreken.
          </Paragraph>
          <ul class="processing-events-list">
            <li class="processing-events-list__item">
              <span class="processing-events-list__message">{latestProcessingError.message}</span>
              <span class="processing-events-list__meta">
                {[formatProcessingEventDate(latestProcessingError.createdAt), processingToolLabels[latestProcessingError.tool] ?? latestProcessingError.tool, processingStatusLabels[latestProcessingError.status] ?? latestProcessingError.status].filter(Boolean).join(" · ")}
              </span>
              {latestProcessingError.detail ? (
                <details class="processing-events-list__details">
                  <summary>Technische details</summary>
                  <pre>{latestProcessingError.detail}</pre>
                </details>
              ) : null}
            </li>
          </ul>
        </Alert>
      ) : null}
      { details.lifecycle.status === 'retired' ? (
        <Alert type="warning">{t("pages.oas-retired-warning")}</Alert>
      ) : (
        <Fragment>
          <Heading level={3}>{t(`pages.tools`)}</Heading>
          <Block appearance="outlined" layout="flex-col" data-track-content data-content-name="Detail Page Tools">
            <AlignBox data-content-piece="OpenAPI Specificatie" align="space-between" gap="small">
              <label for="oasUrl" class="no-shrink">OpenAPI Specificatie</label>
              <ReadOnlyTextInput
                id="oasUrl"
                type="url"
                aria-label="Open Api Specificatie (OAS) URL"
                defaultValue={details.oasUrl || ''}
                name="oasUrl"
              />
              <CopyButton client:load text={details.oasUrl || ''} data-content-target="OAS Copy Button" />
              <Link data-content-target="Fetch in Bruno Button" href={`https://fetch.usebruno.com?url=${details.oasUrl}&type=openapi`} target="_blank" rel="noopener noreferrer"><img src="https://fetch.usebruno.com/button.svg" alt="Fetch in Bruno" width="130" height="30" /></Link>
            </AlignBox>
            {/* biome-ignore lint/a11y/useSemanticElements: ol/ul not possible */}
            <div class="utrecht-badge-list" role="list" data-content-piece="Open OAS in">
              <span class="open-in-label">{t(`components.open-in`)}</span>
              <DataBadgeLink data-content-target="Open OAS in Redoc Link" href={`https://redocly.github.io/redoc/?url=${details.oasUrl}`} target="_blank" rel="noopener" role="listitem">
                ReDoc
              </DataBadgeLink>
              <DataBadgeLink data-content-target="Open OAS in Swagger Link" href={`https://editor-next.swagger.io/?url=${details.oasUrl}`} target="_blank" rel="noopener" role="listitem">
                Swagger (Next)
              </DataBadgeLink>
              <DataBadgeLink data-content-target="Open OAS in Stoplight Link" role="listitem" href={`https://elements-demo.stoplight.io/?spec=${details.oasUrl}`} target="_blank" rel="noopener">
                Stoplight
              </DataBadgeLink>
            </div>
            {/* biome-ignore lint/a11y/useSemanticElements: ol/ul not possible */}
            <div class="utrecht-badge-list" role="list" data-content-piece="Download OAS as">
              <span class="download-as-label">{t(`components.download-as`)}</span>
              <DataBadgeLink data-content-target="Download OAS as Postman collection" href={`download/${id}/postman.json`} role="listitem">Postman Collection (.json)</DataBadgeLink>
              {/* TODO: other way to select your download: */}
              <DataBadgeLink data-content-target="Download OAS as OAS 3.0 (.json)" href={`download/${id}/oas3.0.json`} role="listitem">OAS 3.0 (.json)</DataBadgeLink>
              <DataBadgeLink data-content-target="Download OAS as OAS 3.1 (.json)" href={`download/${id}/oas3.1.json`} role="listitem">OAS 3.1 (.json)</DataBadgeLink>
              <DataBadgeLink data-content-target="Download OAS as OAS 3.0 (.yaml)" href={`download/${id}/oas3.0.yaml`} role="listitem">OAS 3.0 (.yaml)</DataBadgeLink>
              <DataBadgeLink data-content-target="Download OAS as OAS 3.1 (.yaml)" href={`download/${id}/oas3.1.yaml`} role="listitem">OAS 3.1 (.yaml)</DataBadgeLink>
            </div>
            {details.docsUrl ? (
              <AlignBox gap="small" display="inline">
                <span class="read-docs-label">{t(`components.read-documentation-at`)} </span>
                <Link href={details.docsUrl}>{details.docsUrl}</Link>
              </AlignBox>) : null}
          </Block>
          <Heading level={4}>{t(`pages.servers-and-auth`)}</Heading>
          <Block appearance="outlined">
            <Heading level={5}>{t(`pages.servers`)}</Heading>
            <DataSummary appearance="column" contained={!details.auth}>
              {details.servers ? details.servers?.map((server) => (
                <DataSummaryItem itemKey={server.description} itemValue={``} href={server.url}>{server.url}</DataSummaryItem>
              )) : <DataSummaryItem itemValue={t('components.no-items-present', { items: 'servers'})} />}
            </DataSummary>
            {details.auth ? (
              <Fragment>
                <Heading level={5}>{t(`pages.authentication`)}</Heading>
                {/* TODO: Add authentication details here */}
                <pre hidden>{JSON.stringify(details.auth, null, 2)}</pre>
              </Fragment>
            ) : null}
          </Block>
        </Fragment>
        <Heading level={4}>{t("pages.stay-up-to-date-about-api")}</Heading>
        <Block appearance="outlined" layout="flex-col" data-track-content data-content-name="Detail Page Subscribe">
          <AlignBox data-content-piece="RSS Feed" align="space-between" gap="small">
            <label for="rssFeedUrl" class="no-shrink">RSS</label>
            <ReadOnlyTextInput
              id="rssFeedUrl"
              type="url"
              aria-label="RSS feed URL"
              defaultValue={rssFeedUrl}
              name="rssFeedUrl"
            />
            <CopyButton client:load text={rssFeedUrl} data-content-target="RSS Feed Copy Button" />
          </AlignBox>
          <AlignBox data-content-piece="Slack Feed Subscribe Command" align="space-between" gap="small">
            <label for="slackFeedSubscribeCommand" class="no-shrink">Slack</label>
            <ReadOnlyTextInput
              id="slackFeedSubscribeCommand"
              aria-label="Slack feed subscribe commando"
              defaultValue={slackFeedSubscribeCommand}
              name="slackFeedSubscribeCommand"
            />
            <CopyButton client:load text={slackFeedSubscribeCommand} data-content-target="Slack Feed Subscribe Copy Button" />
          </AlignBox>
        </Block>
      )}
    </Fragment>
</DonDetail>)
}

<style>
  .processing-events-alert {
    margin-block-start: var(--utrecht-space-block-md);
  }

  .processing-events-alert :global(.utrecht-paragraph) {
    margin-block-end: var(--utrecht-space-block-sm);
  }

  .processing-events-list {
    display: grid;
    gap: var(--utrecht-space-block-xs);
    margin-block: 0;
    padding-inline-start: 1.25rem;
  }

  .processing-events-list__item {
    padding-inline-start: var(--utrecht-space-inline-xs);
  }

  .processing-events-list__message,
  .processing-events-list__meta {
    display: block;
  }

  .processing-events-list__meta {
    font-size: 0.875rem;
  }

  .processing-events-list__details {
    margin-block-start: var(--utrecht-space-block-xs);
  }

  .processing-events-list__details summary {
    cursor: pointer;
    font-weight: 700;
  }

  .processing-events-list__details pre {
    max-inline-size: 100%;
    overflow: auto;
    white-space: pre-wrap;
  }
</style>
