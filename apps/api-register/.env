API_URL="https://api.don.projects.digilab.network"
API_ENDPOINT="api-register"
TOOLS_ENDPOINT="tools"
API_VERSION="v1"
# put the correct key in a .env.development.local or .env.production.local file
API_X_API_KEY="your-api-x-api-key"

# Settings voor analytics
PIWIK_PRO_ACCOUNT_ADDRESS="https://statistiek.rijksoverheid.nl"
# put the correct key in a .env.development.local or .env.production.local file
PIWIK_PRO_SITE_ID="your-piwik-site-id"

# Settings for Altcha
ALTCHA_HMAC_KEY="randomlangestringforhmac"

# Settings for parse-link-header
# See: https://www.npmjs.com/package/parse-link-header
# Needed to because the package does not support ES Modules and thus cannot use import.meta.env
# See also ./astro.config.mjs
PARSE_LINK_HEADER_MAXLEN=2000
PARSE_LINK_HEADER_THROW_ON_MAXLEN_EXCEEDED=null
