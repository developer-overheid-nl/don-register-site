---
export const prerender = false; // Not needed in 'server' mode

import {
  API_ENDPOINT,
  API_URL,
  API_VERSION,
  API_X_API_KEY,
  PIWIK_PRO_ACCOUNT_ADDRESS,
  PIWIK_PRO_SITE_ID,
} from "astro:env/server";
import {
  Alert,
  AlignBox,
  Block,
  DataSummary,
  DataSummaryItem,
  Heading,
  HeadingGroup,
  Icon,
  Link,
  Markdown,
  Paragraph,
  PillBadge,
} from "@developer-overheid-nl/don-register-components";
import { PiwikPro } from "@developer-overheid-nl/don-register-components/analytics";
import i18n from "@developer-overheid-nl/don-register-components/i18n";
import {
  DonBasic,
  DonDetail,
} from "@developer-overheid-nl/don-register-layouts";
import { t } from "i18next";
import createClient from "openapi-fetch";
import appConfig from "../../../app.config";
import { ApiPaths, type paths } from "../../types/api-schema";

const { id = "" } = Astro.params;
const API_RESOURCE = ApiPaths.getRepositoryById;

const devStatusColors = {
  concept: "lichtblauw",
  development: "donkerblauw",
  beta: "donkergeel",
  stable: "groen",
  obsolete: "rood",
  unknown: "coolgrey",
};

const client = createClient<paths>({
  baseUrl: `${API_URL}/${API_ENDPOINT}/${API_VERSION}`,
});
const {
  data,
  error,
  response: { status, statusText, headers },
} = await client.GET(API_RESOURCE, {
  params: {
    path: { id },
  },
  headers: {
    "x-api-key": API_X_API_KEY,
  },
});

// Localization
const { i18n: i18nApp } = appConfig;
const i18nPage = {
  "pages.aside-landmark": "Contactinformatie",
};
i18n.addResourceBundle(
  i18n.language,
  "translation",
  i18nApp ? i18nApp[i18n.language] : {},
  true,
  true,
);
i18n.addResources(i18n.language, "translation", i18nPage);

const details = error ? null : data;

const possiblefork =
  details?.publicCode?.url && !details?.url?.includes(details.publicCode?.url);
---

{ error && (
  <DonBasic appConfig={appConfig} titlePage="API niet gevonden">
    <Alert type="error">{(error as unknown as any).message || (error as unknown as any).detail || `${status}: ${statusText}` || t('components.fuzz-error')}</Alert>
    <Paragraph>{t('components.item-not-found-error')}</Paragraph>
  </DonBasic>
)}

{details && (
  <DonDetail appConfig={appConfig} titlePage={details?.name}>
    <PiwikPro slot="head" client:only="react" 
      accountAddress={PIWIK_PRO_ACCOUNT_ADDRESS} 
      siteId={PIWIK_PRO_SITE_ID} 
    />
    <HeadingGroup
      slot="header"
      title={`${t(`pages.details-of-item`)}: ${details?.name}`}
      level={2} 
      data-track-content
      data-content-name="Detail Page Header"
    >
      <Paragraph data-content-piece="Organisation Name" itemScope={true} itemType="https://schema.org/Organization" itemID={details?.organisation?.uri} className={`styles.aboveLink styles.publisher`}>
          <span itemprop="name"><Link data-content-target="Organisation Link" className={`styles.orgLink`} href={new URL(`./?organisation=${details?.organisation?.uri}`, Astro.url).toString()}>
              {details?.organisation?.label}
          </Link></span>
      </Paragraph>
    </HeadingGroup>
    <Fragment slot="description">
      <Heading level={3} className="sr-only">{t(`pages.description`)}</Heading>
      <div class="utrecht-html"><Markdown text={details.longDescription} minHeadingDepth={4} /></div>
      <AlignBox align="top-left" wrap gap="small" className="features">{
        details.publicCode?.description?.nl ? details.publicCode?.description.nl.features?.map((feature) => (
          <span class="feature-pill">{feature}</span>
        )) : ''
      }</AlignBox>
    </Fragment>
    <Fragment slot="aside">
      <DataSummary appearance="row">
        <DataSummaryItem itemKey="Organisatie" itemValue={details?.organisation?.label || '-'} />
        {/* <DataSummaryItem itemKey="Contactpersoon" itemValue={details?.contact?.name || '-'} />
        <DataSummaryItem itemKey="Email" itemValue={details?.contact?.email || '-'} /> */}
      </DataSummary>
    </Fragment>
    <Fragment slot="meta">
      <Block layout="flex-row">
        <Link href={details?.publicCodeUrl || 'https://yml.publiccode.tools/index.html'}><PillBadge startValue={`publiccode.yml`} endValue={details.publicCodeUrl ? details.publicCode?.publiccodeYmlVersion : "NA"} type="color" color={details.publicCodeUrl ? "mintgroen" : "grijs"} /></Link>
        <div>{t(`components.license`, {license: details.publicCode?.legal?.license || 'Onbekend'})}</div>
        <PillBadge startValue={`Status`} endValue={details.publicCode?.developmentStatus || "Onbekend"} type="color" color={devStatusColors[details.publicCode?.developmentStatus || "unknown"]} />
      </Block>
      <Heading level={4}>{t(`pages.details`)}</Heading>
      <Block appearance="outlined">
        {/* <pre style="white-space: pre-wrap;">{JSON.stringify(details.publicCode, undefined, 2)}</pre> */}
        <Heading level={5}>{t(`pages.links`)}</Heading>
        <DataSummary appearance="column" contained>
          <DataSummaryItem itemKey={t(`pages.repository-url`)} itemValue={``} href={details.url}>{details.url}</DataSummaryItem>
          { 
            details.publicCode ? (
              <DataSummaryItem itemKey={t(`pages.public-code-url`)} itemValue={possiblefork ? t(`pages.possible-fork-warning`) : ""} href={details.publicCode?.url}>{details.publicCode?.url}</DataSummaryItem>
            ) : null
          }
        </DataSummary>
        <Heading level={5}>{t(`pages.platform-software`)}</Heading>
          { 
            details.publicCode ? (
        <DataSummary appearance="row" contained>
          <DataSummaryItem itemKey={t(`pages.platforms`)} itemValue={details.publicCode?.platforms?.join(" – ")} href={`https://yml.publiccode.tools/schema.core.html#key-platforms`}><Icon name="info" width="1.5rem" height="1.5rem" /></DataSummaryItem>
          <DataSummaryItem itemKey={t(`pages.software-type`)} itemValue={details.publicCode?.softwareType} href={`https://yml.publiccode.tools/schema.core.html#key-softwaretype`}><Icon name="info" width="1.5rem" height="1.5rem" /></DataSummaryItem>
          <DataSummaryItem itemKey={t(`pages.localisation`)} itemValue={`${details.publicCode?.localisation?.localisationReady ? "✔" : "✘"} — ${details.publicCode?.localisation?.availableLanguages?.join(" – ") || ""}`} href={`https://yml.publiccode.tools/schema.core.html#section-localisation`}><Icon name="info" width="1.5rem" height="1.5rem" /></DataSummaryItem>
          <DataSummaryItem itemKey={t(`pages.maintenance-type`)} itemValue={details.publicCode?.maintenance?.type} href={`https://yml.publiccode.tools/schema.core.html#key-maintenance-type`}><Icon name="info" width="1.5rem" height="1.5rem" /></DataSummaryItem>
        </DataSummary>
            ) : (
              <Alert type="info" className="publiccode-info utrecht-html"><Markdown text={t(`pages.create-a-public-code`)} /></Alert>
            )
          }
      </Block>
      <Heading level={4}>{t(`pages.tbd-metadata`)}</Heading>
      <Block appearance="outlined">
        <DataSummary appearance="column" contained>
          <DataSummaryItem itemKey={t(`components.created-at`)} itemValue={new Date(details.createdAt as string | number).toLocaleDateString('nl-NL')} />
          <DataSummaryItem itemKey={t(`components.last-activity-at`)} itemValue={new Date(details.lastActivityAt as string | number).toLocaleDateString('nl-NL')} />
          <DataSummaryItem itemKey={t(`components.last-crawled-at`)} itemValue={new Date(details.lastCrawledAt as string | number).toLocaleDateString('nl-NL')} />
        </DataSummary>
      </Block>
    </Fragment>
  </DonDetail>
  )
}

<style>
  .features {
    font-size: smaller;
    margin-top: 0.5rem;
  }
  .feature-pill {
    display: inline-block;
    padding-block: 2px;
    padding-inline: 6px;
    background-color: var(--rhc-color-cool-grey-200);
    border-radius: 2px;
  }

  .publiccode-info {
    --utrecht-code-background-color: rgb(from var(--rhc-color-cool-grey-50) r g b / 0.5);
    code {
      padding-inline: 2px;
    }
  }

</style>