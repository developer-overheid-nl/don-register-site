{
  "name": "@developer-overheid-nl/don-register-site",
  "author": "developer.overheid.nl",
  "description": "The sites for the API- and OSS registers",
  "license": "EUPL-1.2",
  "private": true,
  "publishConfig": {
    "access": "restricted"
  },
  "engines": {
    "node": ">=22.12.0 <23 || >=24",
    "pnpm": ">=10"
  },
  "volta": {
    "node": "24.12.0"
  },
  "packageManager": "pnpm@10.27.0",
  "type": "module",
  "scripts": {
    "start": "pnpm run start:api",
    "dev": "pnpm run /^dev:.*/ --parallel",
    "build": "pnpm run /^build:.*/ --parallel",
    "preview": "pnpm run /^preview:.*/ --parallel",
    "start:api": "node apps/api-register/dist/server/entry.mjs --host 0.0.0.0 --port 4321",
    "dev:api": "pnpm --filter @developer-overheid-nl/api-register dev",
    "build:api": "pnpm --filter @developer-overheid-nl/api-register build",
    "preview:api": "pnpm --filter @developer-overheid-nl/api-register preview",
    "start:oss": "node apps/oss-register/dist/server/entry.mjs --host 0.0.0.0 --port 4321",
    "dev:oss": "pnpm --filter @developer-overheid-nl/oss-register dev",
    "build:oss": "pnpm --filter @developer-overheid-nl/oss-register build",
    "preview:oss": "pnpm --filter @developer-overheid-nl/oss-register preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "astro": "astro",
    "test": "vitest",
    "test:storybook": "vitest --project=storybook",
    "ts:oas": "pnpx openapi-typescript --make-paths-enum",
    "ts:test": "tsc --noEmit",
    "biome:check": "biome check --write",
    "biome:migrate": "biome migrate --write",
    "changesets:status": "changeset status --verbose",
    "changesets:version": "changeset version",
    "changesets:version:canary": "changeset version --snapshot canary",
    "changesets:publish": "changeset publish",
    "changesets:publish:canary": "changeset publish --tag canary",
    "chromatic": "chromatic --exit-zero-on-changes"
  },
  "dependencies": {
    "@astrojs/node": "catalog:",
    "@astrojs/react": "catalog:",
    "@developer-overheid-nl/don-register-components": "workspace:*",
    "@developer-overheid-nl/don-register-layouts": "workspace:*",
    "@developer-overheid-nl/proprietary": "workspace:@developer-overheid-nl/proprietary-don@*",
    "@piwikpro/react-piwik-pro": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "astro": "catalog:",
    "clsx": "catalog:",
    "i18next": "catalog:",
    "openapi-fetch": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-markdown": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@changesets/cli": "2.31.0",
    "@chromatic-com/storybook": "5.2.1",
    "@csstools/postcss-global-data": "catalog:",
    "@rijkshuisstijl-community/components-css": "catalog:",
    "@rijkshuisstijl-community/design-tokens": "catalog:",
    "@storybook/addon-a11y": "10.5.0",
    "@storybook/addon-docs": "10.5.0",
    "@storybook/addon-vitest": "10.5.0",
    "@storybook/react-vite": "10.5.0",
    "@utrecht/component-library-css": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "chromatic": "18.0.1",
    "lefthook": "2.1.9",
    "openapi-typescript": "catalog:",
    "playwright": "1.61.1",
    "postcss-custom-media": "catalog:",
    "storybook": "10.5.0",
    "storybook-addon-tag-badges": "3.1.0",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "sharp"
    ],
    "onlyBuiltDependencies": [
      "esbuild",
      "lefthook"
    ]
  }
}